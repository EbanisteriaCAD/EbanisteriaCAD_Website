rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in [
          'burgosaxel56@gmail.com',
          'ebanisteriacad@gmail.com'
        ];
    }

    match /quote-attachments/{quoteId}/{fileName} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /project-files/{projectId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource != null
        && request.resource.size < 20 * 1024 * 1024;
    }

    match /design-gallery/{categorySlug}/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /pricing-richtext/{cardId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /recent-projects/{projectId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /testimonials/{testimonialId}/{fileName} {
      allow read: if true;
      allow write: if isAdmin()
        && request.resource != null
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }
  }
}
