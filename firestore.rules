rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function adminEmails() {
      return exists(/databases/$(database)/documents/siteSettings/public)
        && get(/databases/$(database)/documents/siteSettings/public).data.admin.allowedAdminEmails is list
        ? get(/databases/$(database)/documents/siteSettings/public).data.admin.allowedAdminEmails
        : [
            'burgosaxel56@gmail.com'
          ];
    }

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email in adminEmails();
    }

    function isNonEmptyString(value, max) {
      return value is string
        && value.size() > 0
        && value.size() <= max;
    }

    function hasOnlyKeys(data, allowed) {
      return data.keys().hasOnly(allowed);
    }

    function isDateLike(value) {
      return value is string || value is timestamp;
    }

    function validQuotePayload(data, quoteId) {
      return hasOnlyKeys(data, [
          'id',
          'type',
          'createdAt',
          'updatedAt',
          'name',
          'phone',
          'email',
          'address',
          'zipCode',
          'projectTitle',
          'addressLine',
          'city',
          'stateRegion',
          'postalCode',
          'category',
          'message',
          'measures',
          'material',
          'budget',
          'status',
          'notes',
          'source',
          'attachments',
          'history'
        ])
        && data.id == quoteId
        && data.type is string
        && (data.type == 'quote' || data.type == 'project')
        && isNonEmptyString(data.name, 120)
        && isNonEmptyString(data.phone, 40)
        && isNonEmptyString(data.address, 240)
        && isNonEmptyString(data.city, 120)
        && isNonEmptyString(data.stateRegion, 32)
        && isNonEmptyString(data.zipCode, 20)
        && data.addressLine is string
        && data.postalCode is string
        && isNonEmptyString(data.email, 160)
        && isNonEmptyString(data.category, 80)
        && data.projectTitle is string
        && isNonEmptyString(data.message, 4000)
        && data.status is string
        && (data.status == 'new' || data.status == 'in_progress' || data.status == 'completed' || data.status == 'archived')
        && data.notes is list
        && data.attachments is list
        && data.history is list
        && data.attachments.size() <= 100
        && data.source is string
        && (data.source == 'web_quote' || data.source == 'manual_admin')
        && isDateLike(data.createdAt)
        && isDateLike(data.updatedAt);
    }

    match /projects/{projectId} {
      allow create: if (validQuotePayload(request.resource.data, projectId)
        && request.resource.data.status == 'new'
        && request.resource.data.source == 'web_quote'
      ) || (
        isAdmin()
        && validQuotePayload(request.resource.data, projectId)
      );

      allow read, update, delete: if isAdmin();
    }

    match /quoteRequests/{quoteId} {
      allow create: if (validQuotePayload(request.resource.data, quoteId)
        && request.resource.data.status == 'new'
        && request.resource.data.source == 'web_quote'
      ) || (
        isAdmin()
        && validQuotePayload(request.resource.data, quoteId)
      );

      allow read, update, delete: if isAdmin();
    }

    match /mail/{mailId} {
      allow create: if hasOnlyKeys(request.resource.data, [
          'to',
          'message',
          'quoteId',
          'createdAt',
          'type'
        ])
        && request.resource.data.type == 'quote_receipt'
        && request.resource.data.createdAt is string
        && request.resource.data.quoteId is string
        && request.resource.data.to is list
        && request.resource.data.to.size() == 1
        && request.resource.data.to[0] is string
        && request.resource.data.message is map
        && request.resource.data.message.subject is string
        && request.resource.data.message.text is string
        && request.resource.data.message.html is string;

      allow read, update, delete: if isAdmin();
    }

    match /adminAuditEvents/{eventId} {
      allow read, create: if isAdmin()
        && request.resource.data.id is string
        && request.resource.data.createdAt is string;
      allow update, delete: if false;
    }

    match /designCategories/{categoryId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.id == categoryId;
      allow delete: if isAdmin();
    }

    match /pricingCards/{cardId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.id == cardId;
      allow delete: if isAdmin();
    }

    match /recentProjects/{projectId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.id == projectId;
      allow delete: if isAdmin();
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.id == testimonialId;
      allow delete: if isAdmin();
    }

    match /siteSettings/{settingsId} {
      allow read: if true;
      allow create, update: if isAdmin()
        && request.resource.data.id == settingsId;
      allow delete: if false;
    }
  }
}
